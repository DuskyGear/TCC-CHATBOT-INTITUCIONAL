      "id": "6444cd8d-e8a3-40b4-aa28-2cd39781d77e",
      "name": "EXTRAI O CONTEUDO"
    },
    {
      "parameters": {
        "jsCode": "// ==================================================================\n// 1. Variável com o Texto Bruto\n// ==================================================================\nconst textoBruto = $input.first().json.text;\n\n// ==================================================================\n// 2. Lógica de Limpeza\n// ==================================================================\n\nlet cleanText = textoBruto;\n\n// 2.0 - REMOÇÃO DE CARACTERES NULOS (Unicode Escape Sequence Error)\n// Remove o caractere \\u0000 que causa erro no PostgreSQL/Supabase\ncleanText = cleanText.replace(/\\0/g, '').replace(/\\\\u0000/g, '');\n\n// 2.1 - Padrões de \"lixo\" para remover (LISTA ATUALIZADA)\nconst junkPatterns = [\n    /(\\d{2}\\/\\d{2}\\/\\d{4}\\s+\\d{2}:\\d{2}\\s+SEI\\/IFBA.*?(?:\\d\\/\\d)?)/gs, // Cabeçalho SEI original\n    /\\n\\s*\\d+\\/\\d+\\s*\\n/g,                                             // Numeração de página \"1/3\"\n    /(https?:\\/\\/sei\\.ifba\\.edu\\.br\\/[^\\s]*)/g,                        // Links do SEI no meio\n    /(Documento assinado eletronicamente por.*?decreto.*?)/gs,         // Rodapé Assinatura\n    /(A autenticidade do documento pode ser conferida.*?CRC\\s+[A-F0-9]+.?)/gs, // Validação\n    /23278\\.\\d{6}\\/\\d{4}-\\d{2}\\s+\\d+v\\d/g,                             // Protocolos no final\n    \n    // NOVO: Remove o padrão \"- 4139968 - Edital IFBA\" e variações numéricas\n    /-\\s*\\d+\\s*-\\s*Edital IFBA/g \n];\n\njunkPatterns.forEach(pattern => {\n    cleanText = cleanText.replace(pattern, ' ');\n});\n\n// 2.2 - Remover TODOS os \\n (transformar em linha única)\ncleanText = cleanText.replace(/[\\n\\r]+/g, ' ');\n\n// 2.3 - Remover espaços duplicados/triplos gerados\ncleanText = cleanText.replace(/\\s+/g, ' ');\n\n// 2.4 - Trim (limpar começo e fim)\ncleanText = cleanText.trim();\n\n\n// ==================================================================\n// 3. Retorno\n// ==================================================================\nreturn [\n    { \n        json: { \n            cleanText: cleanText \n        } \n    }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        496,
        48
      ],
      "id": "2242af7e-415b-4520-ae97-788d0a1b7f57",
      "name": "REMOVE LIXO DE CONTEXTO"
    },
    {
      "parameters": {
        "jsCode": "let text = $input.first().json.cleanText || \"\";\n\n// ==================================================================\n// 1. LIMPEZA PRELIMINAR (Normalização)\n// ==================================================================\n// Remove caracteres estranhos e normaliza quebras de linha\ntext = text.replace(/\\r\\n/g, \"\\n\").replace(/\\r/g, \"\\n\");\n// Garante espaço após pontuação se estiver colado (ex: \"Fim.1. Inicio\" -> \"Fim. 1. Inicio\")\ntext = text.replace(/([a-z]\\.)(\\d)/gi, \"$1 $2\");\n\n// ==================================================================\n// 2. MARCAÇÃO DE TÍTULOS (REGEX INTELIGENTE)\n// ==================================================================\n\n/*\n  TRUQUE DO SUCESSO:\n  Usamos \"Positive Lookahead\" (?=[A-Z]) -> O número TEM que ter letra depois.\n  Usamos \"Negative Lookbehind\" (?<!R\\$) -> O número NÃO pode ter R$ antes.\n*/\n\n// A. Títulos Principais (H2 - ##)\n// Ex: \"1. APRESENTAÇÃO\", \"10. DISPOSIÇÕES\"\n// Regra: Numero + Ponto + Espaço + Letras Maiúsculas (pelo menos 3)\ntext = text.replace(\n    /(?:^|\\s)(\\d{1,2}\\.\\s*[A-ZÁÉÍÓÚÇÃÕ\\s-]{3,})(?=\\s|$)/g, \n    '\\n\\n## $1' \n);\n\n// B. Anexos (H2 - ##)\n// Ex: \"Anexo 01 - Barema\"\n// Regra: \"Anexo\" + Numero + Traço (Isso evita \"conforme Anexo 01\")\ntext = text.replace(\n    /(?:^|\\s)(Anexo\\s+\\d+\\s*[-–]\\s*.*?)(?=\\n|$)/gi, \n    '\\n\\n## $1'\n);\n\n// C. Subtítulos (H3 - ###) -- AQUI ESTAVA O ERRO DO DINHEIRO\n// Ex: \"3.1\", \"5.10\"\n// Regra:\n// 1. (?<!...) : Não pode ter R$, nº, Lei, Art antes.\n// 2. (\\d\\.\\d) : O número em si.\n// 3. \\s+      : Tem que ter espaço depois.\n// 4. (?=[A-Z]): TEM QUE TER UMA LETRA DEPOIS (Isso mata o \"60.00 0,00\")\ntext = text.replace(\n    /(?:^|\\s)(?<!R\\$\\s)(?<!nº\\s)(?<!Lei\\s)(?<!Art\\.\\s)(\\d{1,2}\\.\\d{1,2}(?:\\.\\d{1,2})?)\\s+(?=[A-ZÁÉÍÓÚÇÃÕ])/gi, \n    '\\n\\n### $1 ' \n);\n\n// ==================================================================\n// 3. REFINAMENTO FINAL\n// ==================================================================\n// Remove espaços duplos criados\ntext = text.replace(/[ ]+/g, \" \");\n// Remove quebras de linha excessivas (max 2)\ntext = text.replace(/\\n{3,}/g, \"\\n\\n\");\n\nreturn [\n    { \n        json: { \n            markdownText: text.trim() \n        } \n    }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        672,
        48
      ],
      "id": "3abaefb8-ced4-4a94-b696-69b9131f9ea9",
      "name": "APLICA MARKDOWN"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $json.markdownText }}",
        "options": {
          "systemMessage": "# PERSONA\nVocê é um Analista Jurídico e Administrativo Sênior, especializado em leitura e interpretação de atos oficiais brasileiros (Editais, Portarias, Decretos, Leis e Ofícios).\n\n# OBJETIVO\nSua única função é analisar o texto de entrada fornecido e extrair, com extrema síntese e clareza, o \"Objeto\" ou \"Finalidade Principal\" do documento.\n\n# REGRAS DE ANÁLISE\n1. Ignore preâmbulos longos, considerações iniciais (\"CONSIDERANDO que...\") e assinaturas, focando apenas no núcleo da determinação.\n2. Identifique o tipo de documento (Edital, Portaria, etc.) implicitamente para entender o contexto.\n3. Se for um EDITAL: O objetivo geralmente é a contratação de serviço, aquisição de bens ou seleção de candidatos.\n4. Se for uma PORTARIA: O objetivo geralmente é nomear alguém, instituir um grupo de trabalho ou estabelecer uma regra interna.\n\n# FORMATO DA RESPOSTA\n- Retorne APENAS o objetivo. Não use frases como \"O objetivo deste documento é...\". Vá direto ao ponto.\n- Comece a frase sempre com um VERBO NO INFINITIVO (Ex: Contratar, Instituir, Regulamentar, Nomear, Adquirir).\n- Máximo de 2 parágrafos curtos ou 50 palavras.\n\n# TRATAMENTO DE ERROS\n- Se o texto fornecido for ilegível ou não parecer um documento oficial, responda apenas: \"ERRO: Não foi possível identificar o objetivo do documento.\""
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3,
      "position": [
        848,
        48
      ],
      "id": "417d5b0b-6382-4e43-a69f-9e99afe7208b",
      "name": "DEFINE FINALIDADE DO DOCUMENTO"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $('APLICA MARKDOWN').item.json.markdownText }}",
        "options": {
          "systemMessage": "=# PERSONA\nVocê é um Auditor de Documentos Regulatórios do IFBA. Sua função é dupla: classificar documentos juridicamente e gerar metadados técnicos para indexação em banco vetorial.\n\n# DADOS DE ENTRADA\n<nome_arquivo>\n{{ $('RECEBE DOCUMENTOS DRIVE').item.json.name }}\n</nome_arquivo>\n\n<conteudo_documento>\n{{ $('APLICA MARKDOWN').item.json.markdownText }}\n</conteudo_documento>\n\n# 1. ALGORITMO DE CLASSIFICAÇÃO (Prioridade Descendente)\nAnalise o conteúdo e classifique o `tipo_documento` seguindo esta ordem estrita:\n\n1. **RETIFICACAO:** Se houver termos como \"Retificação\", \"Errata\", \"Corrigenda\" ou frases de alteração (\"Onde se lia... leia-se\").\n2. **EDITAL:** Se houver \"Edital de Abertura\", \"Processo Seletivo\" e NÃO for retificação.\n3. **ATA:** Se registrar reuniões, sorteios ou resultados preliminares/finais.\n4. **NORMATIVA:** Portarias, Resoluções, Decretos.\n5. **OUTROS:** Caso não se encaixe acima.\n\n# 2. REGRAS DE EXTRAÇÃO DE DADOS\n\n- **data_documento:** A data de assinatura/publicação deste arquivo específico. Formato ISO estrito: `YYYY-MM-DD`.\n\n- **numero_documento:** O IDENTIFICADOR NUMÉRICO do processo/edital.\n    - **Regra de Ouro:** Extraia APENAS números e ano (formato `NUMERO/ANO`).\n    - **NÃO INCLUA TEXTO:** Remova palavras como \"Edital\", \"Retificação\", \"Ata\", \"nº\", \"de\".\n    - **Se for Edital:** Extraia o número dele (ex: texto \"Edital nº 28/2024\" -> extraia \"28/2024\").\n    - **Se for Retificação/Ata:** Extraia o número do EDITAL PAI a que se refere (ex: texto \"Retificação 01 do Edital 28/2024\" -> extraia \"28/2024\").\n\n# 3. LÓGICA DE NOME PADRONIZADO (Para Filtro Vetorial)\n\nVocê deve gerar um campo `nome_padronizado` no formato: `ID_AGRUPADOR | DATA_ISO | TIPO_SIMPLIFICADO`\n\n**Regras para o ID_AGRUPADOR:**\n- Use exatamente o valor extraído em `numero_documento`, mas substitua a barra \"/\" por hífen \"-\".\n- Exemplo: Se `numero_documento` for \"28/2024\", o ID_AGRUPADOR será \"28-2024\".\n\n**Regras para TIPO_SIMPLIFICADO:**\n- Use apenas uma palavra maiúscula: EDITAL, RETIFICACAO, ATA, RESULTADO, NORMATIVA.\n\n**Exemplo Prático:**\n- Arquivo de entrada: \"1ª Retificação do Edital 28/2024.pdf\" (Data: 15/02/2024)\n- Saída esperada:\n   - `numero_documento`: \"28/2024\"\n   - `nome_padronizado`: \"28-2024 | 2024-02-15 | RETIFICACAO\"\n\n# FORMATO DE SAÍDA (JSON)\nRetorne APENAS um objeto JSON válido.\n\n{\n  \"data_documento\": \"YYYY-MM-DD\",\n  \"tipo_documento\": \"String (Classificação completa ex: Retificação, Edital)\",\n  \"numero_documento\": \"String (Apenas NUMERO/ANO ex: 28/2024)\",\n  \"nome_padronizado\": \"String (ID-AGRUPADOR | DATA | TIPO)\"\n}"
        }
      },
