    {
      "parameters": {
        "jsCode": "// Pega o texto que veio do passo anterior (já com ## e ###)\n// Tenta pegar markdownText ou cleanText (fallback)\nconst text =$('APLICA MARKDOWN').first().json.markdownText;\n\nif (!text) return [];\n\nconst lines = text.split('\\n');\n\nlet result = [];\nlet currentParent = \"CABEÇALHO / PREÂMBULO\";\nlet currentBlock = null;\n\n// REGEX PARA SEPARAR TÍTULO DE CONTEÚDO NA MESMA LINHA\n// Grupo 1: O Título (Números + Letras Maiúsculas + Hifens/Barras)\n// Grupo 2: O resto (O conteúdo misturado)\nconst splitLineRegex = /^(\\d{1,2}\\.\\s*[A-ZÁÉÍÓÚÇÃÕÂÊÔ\\s\\-\\/]+)(.*)/;\n\n// Função para salvar o bloco\nconst saveBlock = () => {\n    if (currentBlock) {\n        const cleanContent = currentBlock.content.trim();\n        \n        // FILTRO DE SEGURANÇA AJUSTADO:\n        // Só deleta se o conteúdo for vazio.\n        // Se o conteúdo tiver texto, salva!\n        if (cleanContent.length < 3) {\n            // Última chance: Se for um Anexo ou um título muito longo que pode ser texto corrido, salva mesmo assim.\n            if (!currentBlock.topic.toLowerCase().includes(\"anexo\") && currentBlock.topic.length < 100) {\n                 return; // Realmente é um título órfão, descarta.\n            }\n        }\n\n        let fullText = \"\";\n        \n        if (currentBlock.type === 'MAIN') {\n             // Formato: \"6. CRONOGRAMA: Será observado...\"\n             fullText = `${currentBlock.topic}: ${cleanContent}`;\n        } else {\n             // Formato: \"4. INSCRIÇÃO > 4.1 Detalhes: texto...\"\n             fullText = `${currentBlock.parent} > ${currentBlock.topic}: ${cleanContent}`;\n        }\n\n        result.push({\n            parent: currentBlock.parent,\n            topic: currentBlock.topic,\n            content: cleanContent,\n            full_text: fullText.trim()\n        });\n    }\n};\n\nlines.forEach(line => {\n    const cleanLine = line.trim();\n    if (!cleanLine) return;\n\n    // A. É TÍTULO PRINCIPAL (## )\n    if (cleanLine.startsWith(\"## \")) {\n        saveBlock(); // Salva o anterior\n\n        let rawText = cleanLine.replace(\"## \", \"\").trim();\n        \n        let title = rawText;\n        let inlineContent = \"\";\n\n        // TENTA SEPARAR TÍTULO E CONTEÚDO\n        // Verifica se a linha tem letras minúsculas (indício de conteúdo)\n        if (/[a-z]/.test(rawText)) {\n            const match = rawText.match(splitLineRegex);\n            if (match) {\n                title = match[1].trim();          // \"6. DO CRONOGRAMA\"\n                inlineContent = match[2].trim();  // \"Será observado...\"\n            }\n        }\n\n        currentParent = title;\n\n        currentBlock = {\n            type: 'MAIN',\n            parent: title,\n            topic: title,\n            content: inlineContent // Já começa com o texto que estava colado!\n        };\n    }\n    // B. É SUBTÓPICO (### )\n    else if (cleanLine.startsWith(\"### \")) {\n        saveBlock(); // Salva o anterior\n\n        let rawText = cleanLine.replace(\"### \", \"\").trim();\n        let topic = rawText;\n        let inlineContent = \"\";\n\n        // Mesma lógica para subtópicos (Ex: \"7.1 - Os resultados...\" -> separa o 7.1 do texto)\n        // Regex simplificado para subtópico (Numero.Numero + Traço opcional + Texto)\n        const subMatch = rawText.match(/^(\\d+\\.\\d+(?:\\.\\d+)?\\s*[-–]?)(.*)/);\n        \n        if (subMatch && /[a-z]/.test(subMatch[2])) {\n             topic = subMatch[1].trim().replace(/[-–]$/, '').trim(); // Remove traço final do tópico\n             inlineContent = subMatch[2].trim();\n        }\n\n        currentBlock = {\n            type: 'SUB',\n            parent: currentParent,\n            topic: topic,\n            content: inlineContent\n        };\n    }\n    // C. É CONTEÚDO (LINHA SOLTA)\n    else {\n        if (currentBlock) {\n            currentBlock.content += \" \" + cleanLine;\n        } else {\n            // Texto introdutório\n            currentBlock = {\n                type: 'MAIN',\n                parent: \"INTRODUÇÃO\",\n                topic: \"INTRODUÇÃO\",\n                content: cleanLine\n            };\n        }\n    }\n});\n\nsaveBlock(); // Salva o último\n\nreturn result.map(i => ({ json: i }));"
      },
